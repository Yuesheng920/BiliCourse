{
  "manifest_version": 3,
  "name": "BiliCourseProgress",
  "version": "1.1.0",
  "description": "在 B 站多 P 视频课程页显示本地学习进度、课程总进度与继续观看预测。",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.bilibili.com/video/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
